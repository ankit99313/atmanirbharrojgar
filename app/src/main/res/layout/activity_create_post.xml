<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CreatePost">


    <LinearLayout
        android:layout_margin="16dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">



        <LinearLayout
            android:layout_marginBottom="16dp"
            android:gravity="right"
            android:id="@+id/relativelayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.cardview.widget.CardView
                android:id="@+id/seepreviouspost"
                android:layout_marginBottom="5dp"
                app:cardBackgroundColor="#0084FF"
                android:gravity="center"
                app:cardElevation="8dp"
                app:cardCornerRadius="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                >

                <TextView

                    android:textSize="17dp"
                    android:textColor="@color/white"
                    android:padding="6dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See previous post"/>


            </androidx.cardview.widget.CardView>

        </LinearLayout>



    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense.ExposedDropdownMenu"
        android:id="@+id/categorylayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Category">

        <AutoCompleteTextView
            android:id="@+id/spinner_profession"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:editable="true"
            android:popupTheme="@style/AppTheme.PopupOverlay"
            android:text="Select"
            tools:ignore="Deprecated" />
    </com.google.android.material.textfield.TextInputLayout>




        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense.ExposedDropdownMenu"
            android:id="@+id/worktimelayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Need worker in">

            <AutoCompleteTextView
                android:id="@+id/spinner_worktime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:editable="true"
                android:popupTheme="@style/AppTheme.PopupOverlay"
                android:text="Select"
                tools:ignore="Deprecated" />
        </com.google.android.material.textfield.TextInputLayout>


        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense.ExposedDropdownMenu"
            android:id="@+id/judgeworklayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Need help to judge your work">

            <AutoCompleteTextView
                android:id="@+id/spinner_judgework"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:editable="true"
                android:popupTheme="@style/AppTheme.PopupOverlay"
                android:text="Yes"
                tools:ignore="Deprecated"/>
        </com.google.android.material.textfield.TextInputLayout>




        <EditText

    android:id="@+id/title"
    tools:layout_editor_absoluteX="103dp"
    tools:layout_editor_absoluteY="507dp"
    android:ems="20"
    android:layout_marginTop="22dp"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:inputType="textMultiLine"
    android:hint="Title or Short description">
</EditText>




        <EditText
            android:id="@+id/longdescription"
            tools:layout_editor_absoluteX="103dp"
            tools:layout_editor_absoluteY="507dp"
            android:ems="20"
            android:layout_marginTop="22dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:hint="Long description">
        </EditText>

        <Button
            android:onClick="create"
            android:id="@+id/createbutton"
            android:layout_marginTop="16dp"
            android:layout_gravity="center"
            android:text="Create Post"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"></Button>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>