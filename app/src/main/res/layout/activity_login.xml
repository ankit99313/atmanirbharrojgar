<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:windowSoftInputMode="stateVisible|adjustPan"
    android:orientation="vertical"
    android:transitionGroup="true"
    android:layout_gravity="center"
    tools:context=".LoginActivity">





    <RelativeLayout

        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="30dp"
        android:paddingRight="16dp"
        android:paddingLeft="16dp"
        android:layout_marginRight="8dp"
        android:layout_marginLeft="8dp"
        android:paddingBottom="30dp">

        <ImageView
            android:layout_marginTop="60dp"
            android:src="@drawable/atmlogo"
            android:layout_width="wrap_content"
            android:layout_height="110dp"></ImageView>



    <LinearLayout
       android:gravity="center"
        android:id="@+id/linearverify"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pleaseverify"
            android:textSize="18sp">

        </TextView>
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/editTextNumberLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"

            android:autofillHints="Enter your number"
            android:hint="Enter your number">

            <com.google.android.material.textfield.TextInputEditText

                android:id="@+id/editTextNumber"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:inputType="number"
                android:maxLines="1"
                />
        </com.google.android.material.textfield.TextInputLayout>





        <TextView
            android:visibility="gone"
            android:id="@+id/button_resend"
            android:layout_marginTop="15dp"
            android:layout_gravity="right"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RESEND OTP IN33">

        </TextView>




            <com.google.android.material.button.MaterialButton
                android:backgroundTint="	#008000"
                android:textColor="@color/black"
                android:layout_marginTop="30dp"
                android:id="@+id/button_continue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"

                android:text="Send Otp"
                android:layout_marginRight="12dp"/>






    </LinearLayout>



</RelativeLayout>


    </LinearLayout>